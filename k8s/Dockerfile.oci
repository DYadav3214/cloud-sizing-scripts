# OCI Cloud Sizing Script runner
FROM python:3.11-slim

LABEL maintainer="Commvault Sales Engineering"
LABEL description="OCI cloud sizing script runner for Kubernetes Jobs"

# Install OCI CLI + kubectl
RUN apt-get update && apt-get install -y curl unzip && \
    curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl" && \
    install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl && \
    rm kubectl && \
    curl -L https://raw.githubusercontent.com/oracle/oci-cli/master/scripts/install/install.sh | bash -s -- --accept-all-defaults && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

ENV PATH="/root/bin:${PATH}"

# Python dependencies
COPY OCI/requirements.txt /tmp/oci-requirements.txt
RUN pip install --no-cache-dir -r /tmp/oci-requirements.txt || \
    pip install --no-cache-dir oci openpyxl pandas

WORKDIR /scripts
COPY OCI/CVOracleCloudSizingScript.py .

COPY k8s/entrypoints/oci-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
